{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/public/mobile-app/index.html"
    },
    {
      "src": "/health",
      "dest": "/api/health.php"
    },
    {
      "src": "/mobile-app",
      "dest": "/public/mobile-app/index.html"
    },
    {
      "src": "/mobile-app/",
      "dest": "/public/mobile-app/index.html"
    },
    {
      "src": "/mobile-app/(assets|canvaskit|icons)/(.*)",
      "dest": "/public/mobile-app/$1/$2"
    },
    {
      "src": "/mobile-app/(.*\\.(js|json|png|ico|wasm|symbols|bin|otf|frag))",
      "dest": "/public/mobile-app/$1"
    },
    {
      "src": "/mobile-app/(.*)",
      "dest": "/public/mobile-app/index.html"
    },
    {
      "src": "/(build|branding|uploads)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/(favicon.ico|robots.txt|index.php)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
